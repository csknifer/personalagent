# Personal Agent CLI - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys
# =============================================================================

# Google Gemini API Key (required for Gemini provider)
GEMINI_API_KEY=

# OpenAI API Key (required for OpenAI provider)
OPENAI_API_KEY=

# Anthropic API Key (required for Anthropic provider)
ANTHROPIC_API_KEY=

# Tavily API Key (for web search in research skill)
TAVILY_API_KEY=

# =============================================================================
# Provider Configuration
# =============================================================================

# Default provider: gemini | openai | anthropic | ollama
PA_PROVIDER=gemini

# Default model for the provider (used if queen/worker models not specified)
PA_MODEL=gemini-2.5-flash

# =============================================================================
# Queen Agent Configuration (Orchestrator)
# =============================================================================

# Provider for Queen agent (defaults to PA_PROVIDER if not set)
PA_QUEEN_PROVIDER=gemini

# Model for Queen agent - use a more capable model for orchestration
PA_QUEEN_MODEL=gemini-3-pro-preview

# =============================================================================
# Worker Agent Configuration (Task Executors)
# =============================================================================

# Provider for Worker agents (defaults to PA_PROVIDER if not set)
PA_WORKER_PROVIDER=gemini

# Model for Worker agents - can use a faster/cheaper model
PA_WORKER_MODEL=gemini-3-flash-preview

# =============================================================================
# Model Parameters
# =============================================================================

# Temperature (0.0 - 2.0, default: 0.7)
PA_TEMPERATURE=0.7

# Max tokens for responses
PA_MAX_TOKENS=8192

# =============================================================================
# Hive Configuration
# =============================================================================

# Maximum concurrent workers
PA_MAX_WORKERS=4

# Worker timeout in milliseconds (default: 300000 = 5 minutes)
PA_WORKER_TIMEOUT=300000

# Ralph Loop max iterations
PA_RALPH_MAX_ITERATIONS=10

# =============================================================================
# Ollama Configuration (for local models)
# =============================================================================

# Ollama host URL
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Debug & Logging
# =============================================================================

# Enable debug mode (true/false)
PA_DEBUG=false

# Log level: debug | info | warn | error
PA_LOG_LEVEL=info
