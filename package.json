{
  "name": "personalagent",
  "version": "0.1.0",
  "description": "A rich CLI-based chat agent with hive architecture (Queen/Worker pattern)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "personalagent": "dist/index.js",
    "pa": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:types": "node scripts/sync-shared-types.mjs",
    "dev:web": "npm run sync:types && concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx src/index.tsx serve",
    "dev:client": "cd web && npm run dev",
    "build:web": "npm run sync:types && cd web && npm run build",
    "serve": "node dist/index.js serve"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "chat",
    "gemini",
    "openai",
    "anthropic",
    "ollama"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.2.3",
    "fast-glob": "^3.3.3",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "linkedom": "^0.18.12",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ollama": "^0.5.11",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "ws": "^8.19.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "playwright": "^1.58.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
